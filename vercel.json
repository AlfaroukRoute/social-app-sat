{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/social-app/**",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "cleanUrls": true
}